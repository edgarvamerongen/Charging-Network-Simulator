venv/
__pycache__/
*.pyc
*.pyo
.DS_Store
*.log
# Ignore everything Claude-local (worktrees, session data, settings) EXCEPT
# shared slash commands, which we track so e.g. /update-tour is available to all.
.claude/*
!.claude/commands/

# Raw OurAirports data. runways.csv (~4 MB) is only used locally by prepare_data.py /
# airport_alternates.py to (re)generate european_airports.csv — not needed at runtime.
# airports.csv IS tracked (despite its size): airport_resolver.py reads it at runtime for
# the /api/import flight resolver (global ICAO/IATA → coords), so it must ship on deploy.
runways.csv

# Server-side custom planes & chargers (user-generated; created at runtime).
# Excluded so deploys never overwrite what users have added on the server.
data/

# Auto-downloaded Wikimedia airport cover photos (curated pics/airports/<ICAO>.jpg
# are tracked; the network-fetched cache is not).
pics/airports/_cache/

# Docs are local scratch (plans, specs, notes) — not needed in the repo.
docs/

# Stray spreadsheets / research data dumps — not part of the app (no .xlsx is tracked).
*.xlsx
# Marketing/asset scratch dropped in the repo root.
/cta_dark.png
/cta_light.png
# OneDrive/Finder copy artifacts ("<name> 2.<ext>"): "embed 2.html",
# "test_embed 2.py", "poster 4daagse 2.jpeg", etc.
* 2.*
